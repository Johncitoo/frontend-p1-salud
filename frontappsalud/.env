# URL base de backend-p1-salud (el backend oficial, con auth/auditoria) que consume
# esta app movil. Expo inyecta automaticamente cualquier variable con prefijo
# EXPO_PUBLIC_ al bundle de JS (no hace falta configuracion extra en SDK 56+).
#
# Valor por defecto: 10.0.2.2 es el alias que usa el emulador de Android para
# llegar al localhost de la maquina host (donde corre `node dist/main` de
# backend-p1-salud). Si pruebas en un dispositivo fisico o iOS, cambialo por la
# IP real de la maquina que corre el backend en tu red local (ej: 192.168.1.13).
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# Modo de autenticacion contra backend-p1-salud. Debe coincidir con AUTH_MODE del
# backend (ver backend-p1-salud/.env). 'mock' manda el header x-identity-user-id
# (sin login real); 'keycloak' usaria un Bearer token real (todavia no implementado
# en esta app: LoginScreen sigue siendo cosmetico). Dejar en mock hasta que haya
# login real conectado a un Keycloak alcanzable.
EXPO_PUBLIC_AUTH_MODE=mock

# Identidad de modo mock. Debe coincidir con el identity_user_id que crea
# backend-p1-salud/src/database/seed.ts (SEED_PROFESIONAL_IDENTITY_USER_ID).
EXPO_PUBLIC_MOCK_IDENTITY_USER_ID=seed-profesional-terreno-01

# Keycloak centralizado del Grupo 12 (Proyecto 12), vía tunel ngrok (puede cambiar,
# ver backend-p1-salud/docs/INTEGRACION-IDENTIDADES-GRUPO12.md). El cliente "p1" es
# público y solo admite el flujo de navegador (Authorization Code + PKCE) - no
# admite login directo usuario/contraseña. Sin efecto mientras AUTH_MODE=mock.
EXPO_PUBLIC_KEYCLOAK_ISSUER=https://underarm-those-stardust.ngrok-free.dev/realms/sistema-centralizado
EXPO_PUBLIC_KEYCLOAK_REALM=sistema-centralizado
EXPO_PUBLIC_KEYCLOAK_CLIENT_ID=p1
