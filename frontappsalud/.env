# URL base de backend-p1-salud (el backend oficial, con auth/auditoria) que consume
# esta app movil.
EXPO_PUBLIC_API_URL=https://backend-p1-salud-production.up.railway.app

# Modo de autenticacion contra backend-p1-salud.
EXPO_PUBLIC_AUTH_MODE=keycloak

# Identidad de modo mock.
EXPO_PUBLIC_MOCK_IDENTITY_USER_ID=seed-profesional-terreno-01

# Keycloak centralizado del Grupo 12
EXPO_PUBLIC_KEYCLOAK_ISSUER=https://underarm-those-stardust.ngrok-free.dev/realms/sistema-centralizado
EXPO_PUBLIC_KEYCLOAK_REALM=sistema-centralizado
EXPO_PUBLIC_KEYCLOAK_CLIENT_ID=p1
EXPO_PUBLIC_KEYCLOAK_ACCESS_ROLE=p1-access
