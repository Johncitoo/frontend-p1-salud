# Copiar a .env y ajustar segun donde corra backend-p1-salud.
# 10.0.2.2 = alias del emulador de Android hacia el localhost del host.
# Para dispositivo fisico / iOS, usar la IP real de la maquina en la red local.
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# 'mock' o 'keycloak' (debe coincidir con AUTH_MODE del backend). 'keycloak' no
# esta implementado aun en esta app (LoginScreen es cosmetico) - dejar en mock.
EXPO_PUBLIC_AUTH_MODE=mock
EXPO_PUBLIC_MOCK_IDENTITY_USER_ID=seed-profesional-terreno-01

# Solo aplica si EXPO_PUBLIC_AUTH_MODE=keycloak. Usar la IP/dominio alcanzable
# desde el emulador o dispositivo (10.0.2.2 en vez de localhost, si es local).
EXPO_PUBLIC_KEYCLOAK_ISSUER=
EXPO_PUBLIC_KEYCLOAK_REALM=sistema-centralizado
EXPO_PUBLIC_KEYCLOAK_CLIENT_ID=
