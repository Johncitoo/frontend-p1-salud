VITE_API_URL=http://localhost:3000

# Mode of authentication: 'mock' for local development or 'keycloak' for centralized identity
VITE_AUTH_MODE=mock

VITE_KEYCLOAK_URL=http://localhost
VITE_KEYCLOAK_REALM=sistema-centralizado
VITE_KEYCLOAK_CLIENT_ID=proyecto-test

# If Keycloak is exposed on port 8080, use:
# VITE_KEYCLOAK_URL=http://localhost:8080
